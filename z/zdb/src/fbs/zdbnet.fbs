include "types.fbs";
namespace ZdbNet.fbs;
struct DBState {
  db:Zfb.ID;
  rn:int64;
}
table Msg_HB {
  host_i_d:uint16;
  state:uint16;
  db_state:[DBState];
}
table Msg_Rep {
  db:Zfb.ID;
  rn:uint64;
  prev_r_n:uint64;
  deleted:bool;
  data:[uint8];		// nested table data
}
union Hdr {
  HB:Msg_HB,
  Rep:Msg_Rep,
  Rec:Msg_Rep
}
table Msg {
  hdr:Hdr;
}
root_type Msg;
