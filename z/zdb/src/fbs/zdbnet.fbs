include "types.fbs";
namespace ZdbNet.fbs;
struct DBState {
  db:Zfb.ID;
  rn:int64;
}
table Heartbeat {
  host_i_d:uint16;
  state:uint16;
  db_state:[DBState];
}
table Object {
  db:Zfb.ID;
  rn:uint64;
  prev_r_n:uint64;
  deleted:bool;
  data:[uint8];		// nested table data
}
union Body {
  HB:Heartbeat,
  Rep:Object,
  Rec:Object
}
table Msg {
  body:Body;
}
root_type Msg;
